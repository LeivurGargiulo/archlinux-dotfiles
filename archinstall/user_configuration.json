    "mirror_config": {
        "mirror_regions": {
            "Argentina": [],
            "Brazil": [],
            "Chile": []
        }
    },
    "network_config": {
        "type": "nm"
    },
    "no_pkg_lookups": false,
    "ntp": true,
    "offline": false,
    "packages": [
        "base-devel",
        "git",
        "curl",
        "wget",
        "nano",
        "vim",
        "zsh",
        "zsh-completions",
        "man-db",
        "man-pages",
        "amd-ucode",
        "bluez",
        "bluez-utils",
        "blueman",
        "ntfs-3g",
        "dosfstools",
        "openssh",
        "btop",
        "fastfetch",
        "reflector"
    ],
    "parallel downloads": 5,
    "profile_config": {
        "gfx_driver": "AMD / ATI (open-source)",
        "greeter": "none",
        "profile": {
            "custom_settings": {},
            "main": "Minimal"
