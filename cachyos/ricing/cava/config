## cava — dark monochrome glossy · leivur
## Docs: https://github.com/karlstav/cava

[general]
framerate = 60
autosens = 1
overshoot = 20
bars = 0          ; 0 = auto según ancho de la terminal
bar_width = 2
bar_spacing = 1

[input]
method = pulse    ; PipeWire expone pulse; si falla, probá: method = pipewire
source = auto

[output]
method = ncurses
channels = stereo
mono_option = average

[color]
## Monocromático: gradiente de gris a blanco para el "glass"
gradient = 1
gradient_count = 6
gradient_color_1 = '#333333'
gradient_color_2 = '#555555'
gradient_color_3 = '#777777'
gradient_color_4 = '#999999'
gradient_color_5 = '#cccccc'
gradient_color_6 = '#ffffff'

[smoothing]
noise_reduction = 0.77
